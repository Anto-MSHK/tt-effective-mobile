# PostgreSQL (Prisma) — в docker-compose хост для приложения: db
DATABASE_URL=postgresql://app:secret@db:5432/userservice

# JWT (минимум 32 символа — проверяется Zod при старте)
JWT_SECRET=change-me-in-production-min-32-chars-long-secret

# Первый admin (prisma db seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin1!Strong
SEED_ADMIN_FULL_NAME=System Administrator
SEED_ADMIN_DATE_OF_BIRTH=1990-01-01

# TTL в секундах: access 15 мин, refresh 7 дней
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

BCRYPT_ROUNDS=12

# Redis — в compose хост: redis
REDIS_URL=redis://redis:6379

# Rate limit для /auth/*
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=900000

PORT=3000
NODE_ENV=development

# CORS — разрешённые origins (через запятую или * для всех)
CORS_ORIGIN=*

# Локально без Docker (пример):
# DATABASE_URL=postgresql://app:secret@localhost:5432/userservice
# REDIS_URL=redis://localhost:6379
